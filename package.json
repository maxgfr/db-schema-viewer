{
	"name": "db-schema-viewer",
	"version": "1.1.6",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter db-schema-toolkit dev & next dev --turbo",
		"build": "pnpm --filter db-schema-toolkit build && next build",
		"build:pkg": "pnpm --filter db-schema-toolkit build",
		"build:export": "pnpm --filter db-schema-toolkit build && NEXT_OUTPUT_MODE=export next build",
		"start": "next start",
		"lint": "pnpm --filter db-schema-toolkit lint; eslint src/",
		"typecheck": "pnpm --filter db-schema-toolkit typecheck && tsc --noEmit",
		"test": "vitest",
		"test:ci": "pnpm --filter db-schema-toolkit test:ci && vitest run",
		"test:coverage": "vitest run --coverage",
		"fetch-models": "node scripts/fetch-models.mjs",
		"release": "semantic-release"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^2.0.53",
		"@ai-sdk/google": "^2.0.44",
		"@ai-sdk/mistral": "^2.0.25",
		"@ai-sdk/openai": "^2.0.79",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@xyflow/react": "^12.6.0",
		"ai": "^5.0.108",
		"clsx": "^2.1.1",
		"db-schema-toolkit": "workspace:*",
		"html-to-image": "^1.11.11",
		"js-cookie": "^3.0.5",
		"jspdf": "^2.5.2",
		"lucide-react": "^0.556.0",
		"lz-string": "^1.5.0",
		"next": "^16.0.10",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"react-markdown": "^10.1.0",
		"recharts": "^3.5.1",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.0.3",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"semantic-release": "^25.0.3",
		"@tailwindcss/postcss": "^4.1.17",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.0",
		"@types/js-cookie": "^3.0.6",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.5.2",
		"eslint": "^9.39.1",
		"eslint-config-next": "^16.0.7",
		"happy-dom": "^18.0.1",
		"postcss": "^8.5.6",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vitest": "^3.2.1"
	},
	"packageManager": "pnpm@10.30.0"
}
