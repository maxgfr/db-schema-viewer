{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    ["@semantic-release/npm", { "npmPublish": false }],
    ["@semantic-release/exec", {
      "prepareCmd": "cd packages/db-schema-toolkit && pnpm build && tar -czf ../../db-schema-toolkit-cli-${nextRelease.version}.tar.gz -C dist cli.js"
    }],
    ["@semantic-release/npm", { "pkgRoot": "packages/db-schema-toolkit" }],
    ["@semantic-release/git", {
      "assets": ["package.json", "CHANGELOG.md", "packages/db-schema-toolkit/package.json"],
      "message": "chore(release): ${nextRelease.version} [skip ci]"
    }],
    ["@semantic-release/github", {
      "assets": [
        {
          "path": "db-schema-toolkit-cli-${nextRelease.version}.tar.gz",
          "name": "db-schema-toolkit-cli-${nextRelease.version}.tar.gz",
          "label": "CLI (Node.js)"
        }
      ]
    }]
  ]
}
